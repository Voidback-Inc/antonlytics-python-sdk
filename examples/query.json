{
  "entities": [
    {
      "alias": "customer1",
      "type": "Customer",
      "properties": ["name", "email", "country", "age"],
      "filters": [
        { "property": "country", "operator": "eq",  "value": "USA" },
        { "property": "age",     "operator": "gte", "value": 18 }
      ],
      "relationship": { "type": "PURCHASED", "target": "product1" }
    },
    {
      "alias": "product1",
      "type": "Product",
      "properties": ["title", "price"],
      "filters": [
        { "property": "price", "operator": "lte", "value": 1500 }
      ]
    }
  ],
  "orderBy": { "property": "age", "direction": "desc" },
  "limit": 25
}
